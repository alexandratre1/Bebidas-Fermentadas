#!/bin/bash
# ==========================================
# PIPELINE: TRIMMING FOR PAIRED-END DATA (PE)
# ==========================================

# --- CONFIGURACIÓN DE LA MUESTRA Y RUTAS ---
BEBIDA="pozol"  # <--- ¡CAMBIA AQUÍ LA BEBIDA! (pozol, kefir, kombucha, pulque)
BASE_DIR="/data2/Alexandra/${BEBIDA}"

# Ruta al adaptador Paired-End en tu entorno Conda (TruSeq3-PE.fa)
ADAPTERS="$HOME/.conda/envs/metagenomics/share/trimmomatic-0.39-2/adapters/TruSeq3-PE.fa"
THREADS=4

# Carpetas de entrada y salida
INPUT_DIR="${BASE_DIR}/raw_reads"
OUTPUT_DIR="${BASE_DIR}/trimmed_${BEBIDA}"

# Crear carpeta de salida si no existe
mkdir -p "$OUTPUT_DIR"

echo "✂️ Iniciando Trimming en modo Paired-End para: $BEBIDA..."
echo "🔍 Buscando archivos en: $INPUT_DIR"

# Recorre todos los archivos forward que terminen en _1.fastq.gz
for r1_file in "$INPUT_DIR"/*_1.fastq.gz; do
    # Validar si existen archivos con ese patrón
    [ -e "$r1_file" ] || continue

    # Detectar automáticamente el archivo reverse correspondiente (_2.fastq.gz)
    r2_file="${r1_file/_1.fastq.gz/_2.fastq.gz}"
    
    # Obtener el nombre base de la muestra (ej. SRR123456)
    base=$(basename "$r1_file" _1.fastq.gz)

    echo "🔄 Procesando pareja: $base"

    # Ejecutar Trimmomatic en modo PE
    # Genera 4 archivos de salida: 2 pareados (paired) y 2 huérfanos (unpaired)
    trimmomatic PE -threads $THREADS "$r1_file" "$r2_file" \
        "${OUTPUT_DIR}/${base}_1_paired.fastq.gz" "${OUTPUT_DIR}/${base}_1_unpaired.fastq.gz" \
        "${OUTPUT_DIR}/${base}_2_paired.fastq.gz" "${OUTPUT_DIR}/${base}_2_unpaired.fastq.gz" \
        ILLUMINACLIP:${ADAPTERS}:2:30:10 SLIDINGWINDOW:4:20 MINLEN:50
done

echo "✅ Trimming Paired-End para $BEBIDA completado con éxito."
echo "📁 Archivos limpios guardados en: $OUTPUT_DIR"
